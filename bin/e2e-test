#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
MODE=${1:-headless}
TARGET=${2:-}

case "$MODE" in
  headless | debug) ;;
  *)
    echo "Usage: bin/e2e-test [headless|debug] [test name or spec path]" >&2
    exit 1
    ;;
esac

cd "$REPO_ROOT"
# Dummy GA credentials so the service worker attempts delivery; consent specs
# capture the fetch inside the worker, so nothing reaches real GA4.
GA_MEASUREMENT_ID="${GA_MEASUREMENT_ID:-G-E2ETEST}" \
  GA_API_SECRET="${GA_API_SECRET:-e2e-test-secret}" \
  yarn build:analytics

TEST_ARGS=()
if [[ -n "$TARGET" ]]; then
  if [[ "$TARGET" == *.spec.ts || "$TARGET" == tests/* ]]; then
    TEST_ARGS+=("$TARGET")
  else
    TEST_ARGS+=("-g" "$TARGET")
  fi
fi

if [[ "$MODE" == "debug" ]]; then
  if [[ ${#TEST_ARGS[@]} -gt 0 ]]; then
    PLAYWRIGHT_HEADLESS=false PWDEBUG=1 yarn test:e2e "${TEST_ARGS[@]}"
  else
    PLAYWRIGHT_HEADLESS=false PWDEBUG=1 yarn test:e2e
  fi
else
  if [[ ${#TEST_ARGS[@]} -gt 0 ]]; then
    yarn test:e2e "${TEST_ARGS[@]}"
  else
    yarn test:e2e
  fi
fi
