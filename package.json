{
  "name": "chapshuffule",
  "version": "0.1.0",
  "description": "Shuffle YouTube video chapters — Chrome extension",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "test": "jest",
    "build": "node build.js",
    "watch": "node build.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testMatch": ["**/tests/**/*.test.ts"]
  }
}
