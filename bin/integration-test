#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
MODE=${1:-headless}

case "$MODE" in
  headless | debug) ;;
  *)
    echo "Usage: bin/integration-test [headless|debug]" >&2
    exit 1
    ;;
esac

cd "$REPO_ROOT"
yarn build:prod

if [[ "$MODE" == "debug" ]]; then
  PLAYWRIGHT_HEADLESS=false PWDEBUG=1 yarn test:integration
else
  yarn test:integration
fi
