{
  "name": "chapshuffle",
  "version": "0.1.0",
  "description": "Shuffle YouTube video chapters — Chrome extension",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "test": "jest",
    "build": "node build.js",
    "build:prod": "node build.js --prod",
    "watch": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,html,css}\""
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "globals": {
      "__DEV__": true
    },
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^preact/jsx-runtime$": "<rootDir>/node_modules/preact/jsx-runtime/dist/jsxRuntime.js",
      "^preact/hooks$": "<rootDir>/node_modules/preact/hooks/dist/hooks.js",
      "^preact$": "<rootDir>/node_modules/preact/dist/preact.js"
    }
  },
  "dependencies": {
    "preact": "^10.29.2"
  }
}
