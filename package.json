{
  "name": "chapshuffle",
  "version": "0.1.0",
  "description": "Shuffle YouTube video chapters — Chrome extension",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "test": "jest",
    "test:e2e": "playwright test",
    "build": "node build.js",
    "build:prod": "node build.js --prod",
    "sync:branding": "node scripts/sync-branding.js",
    "watch": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,css}\" \"tests/e2e/**/*.{ts,tsx,html}\" playwright.config.ts",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,html,css}\" \"tests/e2e/**/*.{ts,tsx,html}\" playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.287",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "globals": {
      "__DEV__": false
    },
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testMatch": [
      "**/tests/unit/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/compiled/",
      "/.claude/"
    ],
    "moduleNameMapper": {
      "^preact/jsx-runtime$": "<rootDir>/node_modules/preact/jsx-runtime/dist/jsxRuntime.js",
      "^preact/hooks$": "<rootDir>/node_modules/preact/hooks/dist/hooks.js",
      "^preact$": "<rootDir>/node_modules/preact/dist/preact.js",
      "^preact/test-utils$": "<rootDir>/node_modules/preact/test-utils/dist/testUtils.js"
    }
  },
  "dependencies": {
    "preact": "^10.29.2"
  }
}
