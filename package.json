{
  "name": "chapshuffle",
  "version": "0.1.0",
  "description": "Shuffle YouTube video chapters — Chrome extension",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "test": "jest",
    "build": "node build.js",
    "watch": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,html,css}\""
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
